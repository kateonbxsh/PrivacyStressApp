generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  createdAt    DateTime          @default(now())
  links        UserProfileLink[]
}

model SensitiveProfile {
  id                String            @id @default(cuid())
  encryptedVector   Bytes
  vectorIv          Bytes
  vectorAuthTag     Bytes
  wrappedDek        Bytes
  wrappedDekIv      Bytes
  wrappedDekAuthTag Bytes
  salt              Bytes
  vectorDimension   Int
  createdAt         DateTime          @default(now())
  links             UserProfileLink[]
}

model UserProfileLink {
  id         String           @id @default(cuid())
  userId     String           @unique
  profileId  String           @unique
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile    SensitiveProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
